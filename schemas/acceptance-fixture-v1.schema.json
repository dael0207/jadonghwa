{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-discovery.local/schemas/acceptance-fixture-v1.schema.json",
  "title": "Acceptance Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixture_id",
    "kind",
    "scenario",
    "input_file_refs",
    "expected_file_refs",
    "execution_command",
    "assertions"
  ],
  "properties": {
    "fixture_id": { "type": "string", "minLength": 1 },
    "kind": {
      "type": "string",
      "enum": ["NORMAL", "ERROR", "EXCEPTION", "APPROVAL_REQUIRED"]
    },
    "scenario": { "type": "string", "minLength": 1 },
    "input_file_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected_file_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_command": { "type": "string", "minLength": 1 },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "operator", "expected"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "operator": {
            "type": "string",
            "enum": ["EQUALS", "CONTAINS", "EXISTS", "TYPE_IS", "APPROVAL_REQUIRED"]
          },
          "expected": {}
        }
      }
    }
  }
}
