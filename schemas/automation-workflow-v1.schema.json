{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-discovery.local/schemas/automation-workflow-v1.schema.json",
  "title": "Automation Workflow v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "name",
    "trigger",
    "schedule",
    "completion_condition",
    "steps"
  ],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["MANUAL", "SCHEDULE", "FILE_ARRIVAL", "API_REQUEST"]
        },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "schedule": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["timezone", "cron"],
      "properties": {
        "timezone": { "type": "string", "minLength": 1 },
        "cron": { "type": "string", "minLength": 1 }
      }
    },
    "completion_condition": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step_id",
          "name",
          "action",
          "depends_on",
          "input_refs",
          "output_refs",
          "rule_refs",
          "human_gate",
          "retry_policy"
        ],
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "minLength": 1 },
          "depends_on": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1 }
          },
          "input_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "output_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "rule_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "human_gate": { "type": ["string", "null"] },
          "retry_policy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["max_attempts", "backoff_seconds"],
            "properties": {
              "max_attempts": { "type": "integer", "minimum": 1 },
              "backoff_seconds": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    }
  }
}
