{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/opportunity-v1.schema.json",
  "title": "Work Discovery AI Automation Opportunity v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "opportunity_id",
    "project_id",
    "work_model_id",
    "target_refs",
    "problem_statement",
    "recommendation",
    "alternative_options",
    "scores",
    "gate",
    "risk_profile",
    "human_role",
    "benefit_estimate",
    "risks",
    "prerequisites",
    "evidence_refs",
    "open_questions",
    "validation_experiment",
    "mvp_scope",
    "non_goals",
    "created_at"
  ],
  "properties": {
    "opportunity_id": { "$ref": "#/$defs/id" },
    "project_id": { "$ref": "#/$defs/id" },
    "work_model_id": { "$ref": "#/$defs/id" },
    "target_refs": { "$ref": "#/$defs/idArray" },
    "problem_statement": { "type": "string", "minLength": 1, "maxLength": 3000 },
    "recommendation": { "$ref": "#/$defs/solutionOption" },
    "alternative_options": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "#/$defs/solutionOption" }
    },
    "rejected_options": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["solution_mode", "reason"],
        "properties": {
          "solution_mode": { "$ref": "#/$defs/solutionMode" },
          "reason": { "type": "string", "minLength": 1, "maxLength": 2000 }
        }
      },
      "default": []
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "feasibility", "risk", "evidence_confidence", "oversight", "portfolio_class"],
      "properties": {
        "value": { "type": "number", "minimum": 0, "maximum": 100 },
        "feasibility": { "type": "number", "minimum": 0, "maximum": 100 },
        "risk": { "type": "integer", "minimum": 0, "maximum": 4 },
        "evidence_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "oversight": { "type": "integer", "minimum": 0, "maximum": 5 },
        "portfolio_class": {
          "type": "string",
          "enum": ["QUICK_WIN", "STRATEGIC_BET", "ENABLE_FIRST", "HUMAN_CONTROLLED", "NO_BUILD", "DO_NOT_AUTOMATE"]
        },
        "score_explanation": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["result", "blocked_reasons"],
      "properties": {
        "result": {
          "type": "string",
          "enum": ["BLOCKED", "DISCOVERY_NEEDED", "ENABLE_FIRST", "READY_FOR_DESIGN"]
        },
        "blocked_reasons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "risk_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "safety_policy_constraints",
        "inherent_risk_constraints",
        "unresolved_risk_constraints",
        "controlled_risk_constraints",
        "unresolved_exceptions",
        "controlled_exceptions",
        "authority_boundary_confirmed",
        "authority_controls",
        "open_contradictions",
        "residual_risk"
      ],
      "properties": {
        "safety_policy_constraints": { "$ref": "#/$defs/stringArray" },
        "inherent_risk_constraints": { "$ref": "#/$defs/stringArray" },
        "unresolved_risk_constraints": { "$ref": "#/$defs/stringArray" },
        "controlled_risk_constraints": { "$ref": "#/$defs/stringArray" },
        "unresolved_exceptions": { "$ref": "#/$defs/stringArray" },
        "controlled_exceptions": { "$ref": "#/$defs/stringArray" },
        "authority_boundary_confirmed": { "type": "boolean" },
        "authority_controls": { "$ref": "#/$defs/stringArray" },
        "open_contradictions": { "type": "integer", "minimum": 0 },
        "residual_risk": { "type": "integer", "minimum": 0, "maximum": 4 }
      }
    },
    "human_role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retained_responsibilities", "approval_points", "exception_handling", "override_available"],
      "properties": {
        "retained_responsibilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "approval_points": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "exception_handling": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "override_available": { "type": "boolean" }
      }
    },
    "benefit_estimate": { "$ref": "#/$defs/benefitEstimate" },
    "risks": {
      "type": "array",
      "items": { "$ref": "#/$defs/risk" }
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_refs": { "$ref": "#/$defs/idArray" },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "validation_experiment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hypothesis", "method", "sample", "success_criteria"],
      "properties": {
        "hypothesis": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "method": { "type": "string", "minLength": 1, "maxLength": 3000 },
        "sample": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "success_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "mvp_scope": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "idArray": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "solutionMode": {
      "type": "string",
      "enum": [
        "NO_ACTION",
        "ELIMINATE",
        "SIMPLIFY_STANDARDIZE",
        "EXISTING_TOOL",
        "KNOWLEDGE_ASSIST",
        "FORM_DASHBOARD",
        "INTEGRATION_WORKFLOW",
        "DETERMINISTIC_AUTOMATION",
        "DOCUMENT_AI",
        "AI_ASSISTANT",
        "APPROVAL_AGENT",
        "CUSTOM_APP",
        "HUMAN_ONLY"
      ]
    },
    "solutionOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["solution_mode", "title", "rationale", "scope", "autonomy_level"],
      "properties": {
        "solution_mode": { "$ref": "#/$defs/solutionMode" },
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "rationale": { "type": "string", "minLength": 1, "maxLength": 4000 },
        "scope": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "autonomy_level": { "type": "integer", "minimum": 0, "maximum": 5 }
      }
    },
    "benefitEstimate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["basis", "annual_manual_hours", "annual_rework_hours", "recoverable_hours", "annual_total_benefit", "build_cost", "annual_run_cost", "assumptions"],
      "properties": {
        "basis": {
          "type": "string",
          "enum": ["MEASURED", "USER_ESTIMATE", "MIXED", "UNKNOWN"]
        },
        "annual_manual_hours": { "$ref": "#/$defs/range" },
        "annual_rework_hours": { "$ref": "#/$defs/range" },
        "recoverable_hours": { "$ref": "#/$defs/range" },
        "annual_total_benefit": { "$ref": "#/$defs/moneyRange" },
        "build_cost": { "$ref": "#/$defs/moneyRange" },
        "annual_run_cost": { "$ref": "#/$defs/moneyRange" },
        "assumptions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 },
        "typical": { "type": "number", "minimum": 0 }
      }
    },
    "moneyRange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "min", "max"],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 },
        "typical": { "type": "number", "minimum": 0 }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "level", "description", "control", "residual_level"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["PRIVACY", "SECURITY", "LEGAL", "FINANCIAL", "SAFETY", "QUALITY", "REPUTATION", "AUTHORITY", "OPERATIONS", "OTHER"]
        },
        "level": { "type": "integer", "minimum": 0, "maximum": 4 },
        "description": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "control": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "residual_level": { "type": "integer", "minimum": 0, "maximum": 4 }
      }
    }
  }
}
