{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-discovery.local/schemas/implementation-package-v1.schema.json",
  "title": "Implementation Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_id",
    "project_id",
    "source_work_model_id",
    "source_work_model_version",
    "source_opportunity_id",
    "source_design_package_id",
    "source_blueprint_id",
    "readiness_status",
    "target_runtime",
    "framework",
    "package_manager",
    "execution_interface",
    "workflow",
    "integrations",
    "data_contract",
    "rules",
    "exceptions",
    "reliability",
    "human_oversight",
    "module_responsibilities",
    "operations",
    "acceptance_cases",
    "evidence_refs",
    "codegen_readiness",
    "created_at"
  ],
  "properties": {
    "package_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "source_work_model_id": { "type": "string", "minLength": 1 },
    "source_work_model_version": { "type": "integer", "minimum": 1 },
    "source_opportunity_id": { "type": "string", "minLength": 1 },
    "source_design_package_id": { "type": "string", "minLength": 1 },
    "source_blueprint_id": { "type": "string", "minLength": 1 },
    "readiness_status": {
      "type": "string",
      "enum": ["DESIGN_READY", "IMPLEMENTATION_READY", "CODEGEN_READY"]
    },
    "target_runtime": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "package_manager": { "type": "string", "minLength": 1 },
    "execution_interface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "command", "input_path_argument", "output_path_argument"],
      "properties": {
        "type": { "type": "string", "enum": ["CLI", "HTTP", "SCHEDULED_JOB"] },
        "command": { "type": "string", "minLength": 1 },
        "input_path_argument": { "type": "string", "minLength": 1 },
        "output_path_argument": { "type": "string", "minLength": 1 }
      }
    },
    "workflow": { "$ref": "#/$defs/workflow" },
    "integrations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/integration" }
    },
    "data_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_schema", "output_schema", "field_mappings"],
      "properties": {
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "field_mappings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mapping_id", "source", "target", "transform", "evidence_refs"],
            "properties": {
              "mapping_id": { "type": "string", "minLength": 1 },
              "source": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "transform": { "type": "string", "minLength": 1 },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["calculations", "decisions", "validations"],
      "properties": {
        "calculations": { "$ref": "#/$defs/ruleList" },
        "decisions": { "$ref": "#/$defs/ruleList" },
        "validations": { "$ref": "#/$defs/ruleList" }
      }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["exception_id", "condition", "handling", "evidence_refs"],
        "properties": {
          "exception_id": { "type": "string", "minLength": 1 },
          "condition": { "type": "string", "minLength": 1 },
          "handling": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "reliability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retry", "idempotency", "rollback"],
      "properties": {
        "retry": { "type": "string", "minLength": 1 },
        "idempotency": { "type": "string", "minLength": 1 },
        "rollback": { "type": "string", "minLength": 1 }
      }
    },
    "human_oversight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["approval_points", "override_policy"],
      "properties": {
        "approval_points": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "override_policy": { "type": "string", "minLength": 1 }
      }
    },
    "module_responsibilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "responsibility"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\.\\.).+$"
          },
          "responsibility": { "type": "string", "minLength": 1 }
        }
      }
    },
    "operations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["logging", "audit", "security", "deployment"],
      "properties": {
        "logging": { "type": "string", "minLength": 1 },
        "audit": { "type": "string", "minLength": 1 },
        "security": { "type": "string", "minLength": 1 },
        "deployment": { "type": "string", "minLength": 1 }
      }
    },
    "acceptance_cases": {
      "type": "array",
      "minItems": 4,
      "items": { "$ref": "#/$defs/fixture" }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "codegen_readiness": { "$ref": "#/$defs/readiness" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "ruleList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "expression", "evidence_refs"],
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "expression": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_id",
        "name",
        "trigger",
        "schedule",
        "completion_condition",
        "steps"
      ],
      "properties": {
        "workflow_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "trigger": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "description"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["MANUAL", "SCHEDULE", "FILE_ARRIVAL", "API_REQUEST"]
            },
            "description": { "type": "string", "minLength": 1 }
          }
        },
        "schedule": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["timezone", "cron"],
          "properties": {
            "timezone": { "type": "string", "minLength": 1 },
            "cron": { "type": "string", "minLength": 1 }
          }
        },
        "completion_condition": { "type": "string", "minLength": 1 },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step_id",
              "name",
              "action",
              "depends_on",
              "input_refs",
              "output_refs",
              "rule_refs",
              "human_gate",
              "retry_policy"
            ],
            "properties": {
              "step_id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 },
              "action": { "type": "string", "minLength": 1 },
              "depends_on": {
                "type": "array",
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              },
              "input_refs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "output_refs": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "rule_refs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "human_gate": { "type": ["string", "null"] },
              "retry_policy": {
                "type": "object",
                "additionalProperties": false,
                "required": ["max_attempts", "backoff_seconds"],
                "properties": {
                  "max_attempts": { "type": "integer", "minimum": 1 },
                  "backoff_seconds": { "type": "integer", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "integration_id",
        "system_name",
        "adapter_type",
        "operation",
        "access_mode",
        "auth_mode",
        "environment_variables",
        "timeout_seconds",
        "retry_policy",
        "idempotency_key",
        "evidence_refs"
      ],
      "properties": {
        "integration_id": { "type": "string", "minLength": 1 },
        "system_name": { "type": "string", "minLength": 1 },
        "adapter_type": {
          "type": "string",
          "enum": ["FILE", "REST_API", "DATABASE", "EMAIL", "WEB_UI"]
        },
        "operation": { "type": "string", "minLength": 1 },
        "access_mode": { "type": "string", "enum": ["READ", "WRITE", "READ_WRITE"] },
        "auth_mode": {
          "type": "string",
          "enum": ["NONE", "ENV_REFERENCE", "OAUTH_REFERENCE", "API_KEY_REFERENCE"]
        },
        "environment_variables": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "description", "required", "secret"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "description": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "secret": { "type": "boolean" }
            }
          }
        },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "retry_policy": { "type": "string", "minLength": 1 },
        "idempotency_key": { "type": ["string", "null"] },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "kind",
        "scenario",
        "input_file_refs",
        "expected_file_refs",
        "execution_command",
        "assertions"
      ],
      "properties": {
        "fixture_id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["NORMAL", "ERROR", "EXCEPTION", "APPROVAL_REQUIRED"]
        },
        "scenario": { "type": "string", "minLength": 1 },
        "input_file_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expected_file_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "execution_command": { "type": "string", "minLength": 1 },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "operator", "expected"],
            "properties": {
              "path": { "type": "string", "minLength": 1 },
              "operator": {
                "type": "string",
                "enum": [
                  "EQUALS",
                  "CONTAINS",
                  "EXISTS",
                  "TYPE_IS",
                  "APPROVAL_REQUIRED"
                ]
              },
              "expected": {}
            }
          }
        }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package_id",
        "project_id",
        "status",
        "codegen_ready",
        "blockers",
        "follow_up_questions",
        "checks",
        "evaluated_at"
      ],
      "properties": {
        "package_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["DESIGN_READY", "IMPLEMENTATION_READY", "CODEGEN_READY"]
        },
        "codegen_ready": { "type": "boolean" },
        "blockers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "follow_up_questions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "passed", "detail"],
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "passed": { "type": "boolean" },
              "detail": { "type": "string", "minLength": 1 }
            }
          }
        },
        "evaluated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
