{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-discovery.local/schemas/integration-contract-v1.schema.json",
  "title": "Integration Contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "integration_id",
    "system_name",
    "adapter_type",
    "operation",
    "access_mode",
    "auth_mode",
    "environment_variables",
    "timeout_seconds",
    "retry_policy",
    "idempotency_key",
    "evidence_refs"
  ],
  "properties": {
    "integration_id": { "type": "string", "minLength": 1 },
    "system_name": { "type": "string", "minLength": 1 },
    "adapter_type": {
      "type": "string",
      "enum": ["FILE", "REST_API", "DATABASE", "EMAIL", "WEB_UI"]
    },
    "operation": { "type": "string", "minLength": 1 },
    "access_mode": { "type": "string", "enum": ["READ", "WRITE", "READ_WRITE"] },
    "auth_mode": {
      "type": "string",
      "enum": ["NONE", "ENV_REFERENCE", "OAUTH_REFERENCE", "API_KEY_REFERENCE"]
    },
    "environment_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "description", "required", "secret"],
        "properties": {
          "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
          "description": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "secret": { "type": "boolean" }
        }
      }
    },
    "timeout_seconds": { "type": "integer", "minimum": 1 },
    "retry_policy": { "type": "string", "minLength": 1 },
    "idempotency_key": { "type": ["string", "null"] },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
