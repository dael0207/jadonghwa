{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/release-readiness-v1.schema.json",
  "title": "Work Discovery AI Limited Release Readiness v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "project_id",
    "readiness_status",
    "checklist",
    "blocking_items",
    "source_blueprint_ids",
    "source_design_package_ids",
    "metrics_definition",
    "runbooks",
    "monitoring_placeholder",
    "created_at"
  ],
  "properties": {
    "report_id": { "$ref": "#/$defs/id" },
    "project_id": { "$ref": "#/$defs/id" },
    "readiness_status": { "type": "string", "enum": ["READY", "READY_WITH_BLOCKERS", "NOT_READY"] },
    "checklist": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/checklistItem" }
    },
    "blocking_items": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_blueprint_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "source_design_package_ids": {
      "type": "array",
      "items": { "$ref": "#/$defs/id" },
      "uniqueItems": true
    },
    "metrics_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pilot_metrics", "quality_metrics", "safety_metrics"],
      "properties": {
        "pilot_metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "quality_metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "safety_metrics": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "runbooks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["support", "deletion", "incident_review"],
      "properties": {
        "support": { "type": "string", "minLength": 1 },
        "deletion": { "type": "string", "minLength": 1 },
        "incident_review": { "type": "string", "minLength": 1 }
      }
    },
    "monitoring_placeholder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "events"],
      "properties": {
        "status": { "type": "string", "enum": ["PLACEHOLDER_ONLY"] },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "checklistItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "label", "status", "details"],
      "properties": {
        "key": { "$ref": "#/$defs/id" },
        "label": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["PASS", "WARN", "BLOCKED"] },
        "details": { "type": "string", "minLength": 1 }
      }
    }
  }
}
